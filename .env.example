# OpenRouter API base URL (OpenAI-compatible gateway)
# Judges will override this with their own gateway during scoring.
API_BASE_URL=https://openrouter.ai/api/v1

# Model slug in OpenRouter format: <provider>/<model-name>
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   meta-llama/llama-3.1-70b-instruct
#   mistralai/mistral-7b-instruct:free
MODEL_NAME=openai/gpt-4o-mini

# OpenRouter API key — get one at https://openrouter.ai/keys
# Named HF_TOKEN to match the OpenEnv hackathon spec.
# NEVER commit your real key. Copy this file to .env and fill it in locally.
HF_TOKEN=sk-or-v1-your-key-here
